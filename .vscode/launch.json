    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Go TURN_on_Tailscale",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/TURN_on_Tailscale",
            "cwd": "${workspaceFolder}",
            "args": [
                "--env=.env.node-A"
            ],
            "env": {
                "DEBUG": "true"
            },
            "showLog": true,
            "console": "integratedTerminal",
            "presentation": {
                "group": "Debug Go TURN_on_Tailscale",
                "hidden": false,
                "order": 1
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Run A 5173",
            "runtimeExecutable": "node",
            "program": "C:/Program Files/nodejs/node_modules/npm/bin/npx-cli.js",
            "args": [
                "concurrently",
                "-k",
                "vite --port 5173",
                "cross-env DEV=true electron app/index.cjs --port=5173 --env=.env.node-A"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            // "preLaunchTask": "Build Go"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Run B 5174",
            "runtimeExecutable": "node",
            "program": "C:/Program Files/nodejs/node_modules/npm/bin/npx-cli.js",
            "args": [
                "concurrently",
                "-k",
                "vite --port 5174",
                "cross-env DEV=true electron app/index.cjs --port=5174 --env=.env.node-B"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            // "preLaunchTask": "Build Go"
        }
    ],
    "compounds": [
        {
            "name": "Run A 5173 & B 5174",
            "configurations": [
                "Run A 5173",
                "Run B 5174"
            ],
            "preLaunchTask": "Build Go",
            "stopAll": true,
            "presentation": {
                "group": "Run A 5173 & B 5174",
                "hidden": false,
                "order": 1
            }
        }
    ]
}